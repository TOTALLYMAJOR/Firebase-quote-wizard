{
  "name": "react-firebase-quote-wizard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check:env": "node ./scripts/check-env.mjs",
